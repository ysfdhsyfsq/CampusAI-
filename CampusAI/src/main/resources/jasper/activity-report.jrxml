<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="activity-report" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <property name="net.sf.jasperreports.awt.ignore.missing.font" value="true"/>

    <parameter name="title" class="java.lang.String"/>
    <parameter name="exportTime" class="java.lang.String"/>
    <parameter name="totalCount" class="java.lang.Integer"/>

    <field name="activityTitle" class="java.lang.String"/>
    <field name="maxNum" class="java.lang.Integer"/>
    <field name="enrollNum" class="java.lang.Integer"/>
    <field name="enrollRate" class="java.math.BigDecimal"/>
    <field name="endTime" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>

    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font fontName="宋体" size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[CampusAI 智慧校园]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="40" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font fontName="宋体" size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{title}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader>
        <band height="30">
            <textField>
                <reportElement x="0" y="5" width="275" height="20"/>
                <textElement>
                    <font fontName="宋体" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["导出时间：" + $P{exportTime}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="275" y="5" width="280" height="20"/>
                <textElement textAlignment="Right">
                    <font fontName="宋体" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["活动总数：" + $P{totalCount}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="150" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="宋体" isBold="true"/>
                </textElement>
                <text><![CDATA[活动名称]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="0" width="70" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="宋体" isBold="true"/>
                </textElement>
                <text><![CDATA[名额]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="0" width="70" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="宋体" isBold="true"/>
                </textElement>
                <text><![CDATA[已报名]]></text>
            </staticText>
            <staticText>
                <reportElement x="290" y="0" width="80" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="宋体" isBold="true"/>
                </textElement>
                <text><![CDATA[报名率(%)]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="100" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="宋体" isBold="true"/>
                </textElement>
                <text><![CDATA[截止时间]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="0" width="85" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="宋体" isBold="true"/>
                </textElement>
                <text><![CDATA[状态]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField textAdjust="StretchHeight">
                <reportElement x="0" y="0" width="150" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement><font fontName="宋体"/></textElement>
                <textFieldExpression><![CDATA[$F{activityTitle}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="150" y="0" width="70" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font fontName="宋体"/></textElement>
                <textFieldExpression><![CDATA[$F{maxNum}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="220" y="0" width="70" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font fontName="宋体"/></textElement>
                <textFieldExpression><![CDATA[$F{enrollNum}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="0" width="80" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font fontName="宋体"/></textElement>
                <textFieldExpression><![CDATA[$F{enrollRate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="370" y="0" width="100" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font fontName="宋体"/></textElement>
                <textFieldExpression><![CDATA[$F{endTime}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="470" y="0" width="85" height="20"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"><font fontName="宋体"/></textElement>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="555" height="15"/>
                <textElement textAlignment="Center">
                    <font fontName="宋体" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["第 " + $V{PAGE_NUMBER} + " 页"]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>